{
  "expo": {
    "name": "Easy build",
    "slug": "cost-material",
    "version": "1.0.1",
    "sdkVersion": "52.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a3d62"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.costmaterialapp",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to capture room photos for AI material recognition and AR visualization.",
        "NSPhotoLibraryUsageDescription": "Used to select photos for material analysis and AR visualization.",
        "NSMicrophoneUsageDescription": "Not used."
      }
    },
    "android": {
      "package": "com.costmaterialapp",
      "versionCode": 2,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.INTERNET"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundColor": "#0a3d62"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Easy Build to access your photos for material analysis.",
          "cameraPermission": "Allow Easy Build to use your camera for AI material recognition."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "84321ac4-2c93-41b6-833c-2f31e8d15692"
      }
    }
  }
}
